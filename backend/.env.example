# =============================================================================
# Synapse Backend — Environment Variables
# =============================================================================
# ⚠️  DO NOT COMMIT THIS FILE WITH REAL VALUES.
# Copy this file to .env and fill in your real values.
# =============================================================================

# --- Database ---
MONGO_URI=YOUR_MONGODB_ATLAS_URI
MONGODB_DB=synapse

# --- Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=REPLACE_WITH_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI / LLM ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# --- External Services ---
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY

# --- Application ---
# Set to 'production' when deploying to Render/etc.
ENVIRONMENT=development

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Development defaults (localhost:5173, localhost:3000) are set in config.py.
# Production example:
# CORS_ORIGINS=https://synapse.akshnsh.me
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Cookies ---
# Leave empty for development (browser uses request host).
# Set to your apex domain in production if using subdomains:
#   COOKIE_DOMAIN=akshnsh.me
COOKIE_DOMAIN=

# SameSite cookie policy:
#   "lax"  — same-domain or subdomain deployments (default)
#   "none" — cross-domain deployments (e.g., onrender.com backend → akshnsh.me frontend)
COOKIE_SAMESITE=lax
