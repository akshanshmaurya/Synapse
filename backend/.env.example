# =============================================================================
# Synapse Backend — Environment Variables
# =============================================================================
# ⚠️  DO NOT COMMIT THIS FILE — all values below are REDACTED placeholders.
# Copy this file to .env and fill in your real values.
# =============================================================================

# --- Database ---
MONGO_URI=YOUR_MONGODB_ATLAS_URI
MONGODB_DB=synapse

# --- Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=REPLACE_WITH_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI / LLM ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# --- External Services ---
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY

# --- Application ---
ENVIRONMENT=development
# Set to 'production' when deploying

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Development defaults (localhost:5173, localhost:3000) are set in config.py.
# Override for production:
# CORS_ORIGINS=https://app.yoursite.com,https://yoursite.com

# --- Cookies ---
# Leave empty for development (browser uses localhost default).
# Set to your apex domain in production, e.g.:
# COOKIE_DOMAIN=yoursite.com
COOKIE_DOMAIN=
